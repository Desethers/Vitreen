{
  "name": "galerie-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:webpack": "next dev --webpack -p 3000",
    "dev:clean": "(lsof -ti tcp:3000 2>/dev/null; lsof -ti tcp:3001 2>/dev/null; lsof -ti tcp:3002 2>/dev/null) | sort -u | xargs kill -9 2>/dev/null || true && rm -f .next/dev/lock && next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "generate:variations": "tsx scripts/generate-variations.ts"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "framer-motion": "^12.36.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.10.0"
  },
  "devDependencies": {
    "@ai-sdk/google": "^3.0.53",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "ai": "^6.0.141",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
